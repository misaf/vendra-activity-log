{
    "name": "misaf/vendra-activity-log",
    "description": "Activity log auditing and Filament log management for Vendra",
    "license": "MIT",
    "type": "vendra-module",
    "keywords": [
        "laravel",
        "filamentphp",
        "misaf",
        "vendra",
        "activity",
        "log"
    ],
    "authors": [
        {
            "name": "Ehsan Mahmoodi",
            "email": "misaf.1990@gmail.com",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/misaf/vendra-activity-log",
    "support": {
        "issues": "https://github.com/misaf/vendra-activity-log/issues",
        "source": "https://github.com/misaf/vendra-activity-log"
    },
    "require": {
        "php": "^8.3",
        "awcodes/filament-badgeable-column": "^4.0",
        "filament/filament": "^5.6.8",
        "illuminate/support": "^13.0",
        "misaf/filament-jalali": "^5.1.4",
        "misaf/vendra-support": "self.version",
        "spatie/laravel-activitylog": "^4.12.3",
        "spatie/laravel-package-tools": "^1.93.1"
    },
    "require-dev": {
        "larastan/larastan": "^3.10.0",
        "laravel/boost": "^2.4.12",
        "laravel/pint": "^1.29.3",
        "misaf/vendra-testing": "self.version",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.4",
        "orchestra/testbench": "^11.1",
        "pestphp/pest": "^4.7.5",
        "pestphp/pest-plugin-arch": "^4.0.2",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-profanity": "^4.2.1",
        "pestphp/pest-plugin-type-coverage": "^4.0.4",
        "phpstan/extension-installer": "^1.4.3"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Misaf\\VendraActivityLog\\": "src/",
            "Misaf\\VendraActivityLog\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Misaf\\VendraActivityLog\\Database\\Factories\\": "database/factories/",
            "Misaf\\VendraActivityLog\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Misaf\\VendraActivityLog\\Providers\\ActivityLogServiceProvider"
            ]
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "$schema": "https://getcomposer.org/schema.json"
}
